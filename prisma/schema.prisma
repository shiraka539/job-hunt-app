generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 企業情報
model Company {
  id        String   @id @default(uuid())
  userId    String
  name      String   // 企業名
  status    String   // 選考ステータス（例：未エントリー、ES提出済、1次面接待ち など）
  myPageUrl String?  // マイページのURL（?は空欄OKの意味）
  deadline      DateTime? // ES・選考の締め切り日
  applicationId String?   // 企業発行の管理番号等
  questions     Json?     // ESなどの設問リストを保持するJSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // リレーション：1つの企業は複数の選考フェーズ（Section）を持つ
  sections  Section[]
  
  // 実戦用ボード（企業ごとに紐付けたマスターエピソード）
  tacticalEpisodes CompanyMasterEpisode[]
}

// 選考フェーズ（適性検査、ES、1次面接など）
model Section {
  id        String   @id @default(uuid())
  companyId String
  type      String   // 種類（ES、適性検査、1次面接など）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // リレーション：1つのフェーズは複数の設問（Question）を持つ
  questions Question[]
}

// 設問と回答（エディター部分）
model Question {
  id            String   @id @default(uuid())
  sectionId     String
  title         String   // 設問（見出し）
  content       String?  // 回答内容
  reviewContent String?  // 🌟 これを追加！添削内容を入れる箱だぜ。（? があるから既存データは絶対に消えない！）
  maxLength     Int?     // 文字数上限（空欄なら制限なし）

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

// ワンクリック追加用のひな形（テンプレート）
model Template {
  id          String   @id @default(uuid())
  userId      String
  name        String   // テンプレート名（ガクチカ、自己PRなど）
  defaultText String   // デフォルトの質問文
  createdAt   DateTime @default(now())
}

// 時代区分を定義するEnum
enum Period {
  JUNIOR_HIGH
  HIGH_SCHOOL
  UNIVERSITY
}

// 自分史・ルーツ管理
model LifeHistory {
  id        String   @id @default(cuid())
  userId    String
  period    Period
  title     String
  content   String   @db.Text
  insight   String?  @db.Text // 今の自分への繋がり
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, period])
}

// 汎用エピソード・バンク（面接で使い回すマスター要約）
model MasterEpisode {
  id                String   @id @default(cuid())
  userId            String
  title             String   // 例：「大学時代の研究」「居酒屋のアルバイト」
  category          String?  // 例：「自己PR」「ガクチカ」「困難を乗り越えた経験」
  summaryConclusion String   @db.Text
  summaryChallenge  String   @db.Text
  summaryAction     String   @db.Text
  summaryResult     String   @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  interviewQuestions InterviewQuestion[]
  companyMasterEpisodes CompanyMasterEpisode[]

  @@index([userId]) // ユーザーごとの検索を高速化
}

// 面接対策「実戦用ボード」用の中間テーブル
model CompanyMasterEpisode {
  id              String   @id @default(cuid())
  companyId       String
  masterEpisodeId String
  customMemo      String?  @db.Text // その企業向けの話し方の微調整用メモ
  order           Int      @default(0) // 表示順

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  masterEpisode   MasterEpisode @relation(fields: [masterEpisodeId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, masterEpisodeId])
  @@index([companyId])
  @@index([masterEpisodeId])
}

// 面接で実際に聞かれた質問（アーカイブ）
model InterviewQuestion {
  id              String   @id @default(cuid())
  userId          String
  content         String   @db.Text // 聞かれた質問の内容
  companyName     String?  // どの企業の面接か
  masterEpisodeId String?  // 紐付けるマスターエピソードのID
  answerMemo      String?  @db.Text // その時どう答えたか、感触はどうだったかのメモ
  isFrequent      Boolean  @default(false) // 頻出質問フラグ
  createdAt       DateTime @default(now())

  // リレーション
  masterEpisode   MasterEpisode? @relation(fields: [masterEpisodeId], references: [id], onDelete: SetNull)

  @@index([userId])
}